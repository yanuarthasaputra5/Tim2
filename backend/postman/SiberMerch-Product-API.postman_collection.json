                  "var json = pm.response.json();",
                  "pm.test('success true', function () { pm.expect(json.success).to.eql(true); });",
                  "pm.test('Slug ter-generate', function () { pm.expect(json.data.slug).to.match(/^[a-z0-9\\-]+$/); });",
