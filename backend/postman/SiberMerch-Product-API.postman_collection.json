              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Nama terupdate', function () { pm.expect(json.data.name).to.eql('Kaos Distro'); });"
                ]
              }
