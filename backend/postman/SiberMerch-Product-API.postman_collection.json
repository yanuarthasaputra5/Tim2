{
  "info": {
    "name": "SiberMerch Product API",
    "description": "Test cases lengkap untuk modul Manajemen Produk (Product, Variant, Image, Category) Laravel Sanctum + Spatie. Jalankan berurutan dari atas: login admin -> buat kategori -> buat produk -> varian/gambar -> update -> sync -> delete. ID ditangkap otomatis ke collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "user_token", "value": "", "type": "string" },
    { "key": "status_id", "value": "1", "type": "string" },
    { "key": "status_id_2", "value": "2", "type": "string" },
    { "key": "category_id", "value": "", "type": "string" },
    { "key": "category_id_2", "value": "", "type": "string" },
    { "key": "product_id", "value": "", "type": "string" },
    { "key": "variant_id", "value": "", "type": "string" },
    { "key": "image_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "0. Setup - Login",
      "item": [
        {
          "name": "Login Admin (manage-products)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Ada access_token', function () { pm.expect(json.data.access_token).to.be.a('string'); });",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('admin_token', json.data.access_token);",
                  "  console.log('Admin token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login admin (punya view-products + manage-products) dari seeder."
          }
        },
        {
          "name": "Login User (view-products only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('user_token', json.data.access_token);",
                  "  console.log('User token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login user biasa (hanya view-products) dari seeder. Dipakai untuk uji 403 pada operasi kelola."
          }
        }
      ]
    },
    {
      "name": "1. Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
