      ]
    },
    {
      "name": "2. Products",
      "item": [
        {
          "name": "Create Product (nested variants, images, categories)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('success true', function () { pm.expect(json.success).to.eql(true); });",
                  "pm.test('Slug valid', function () { pm.expect(json.data.slug).to.match(/^[a-z0-9\\-]+$/); });",
                  "pm.test('Relasi lengkap', function () {",
                  "  pm.expect(json.data).to.have.property('status');",
                  "  pm.expect(json.data).to.have.property('categories');",
                  "  pm.expect(json.data).to.have.property('images');",
                  "  pm.expect(json.data).to.have.property('variants');",
                  "});",
                  "pm.test('Varian ikut tersimpan', function () { pm.expect(json.data.variants.length).to.be.above(0); });",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('product_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kaos Polos Premium\",\n  \"description\": \"Kaos katun combed 30s\",\n  \"price\": 75000,\n  \"stock\": 100,\n  \"status_id\": {{status_id}},\n  \"categories\": [{{category_id}}],\n  \"variants\": [\n    { \"name\": \"M\", \"price\": 0, \"stock\": 20, \"status_id\": {{status_id}} },\n    { \"name\": \"XXL\", \"price\": 10000, \"stock\": 10, \"status_id\": {{status_id}} },\n    { \"name\": \"Lengan Panjang\", \"price\": 15000, \"stock\": 15, \"status_id\": {{status_id}} }\n  ],\n  \"images\": [\n    { \"url\": \"https://example.com/kaos-1.jpg\", \"is_primary\": true, \"sort_order\": 0 },\n    { \"url\": \"https://example.com/kaos-2.jpg\", \"sort_order\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            },
            "description": "Membuat produk beserta varian (opsi M/XXL/Lengan Panjang dengan harga tambahan masing-masing), gambar, dan asosiasi kategori dalam satu transaksi."
          }
        },
        {
          "name": "List Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
